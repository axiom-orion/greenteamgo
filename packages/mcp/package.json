    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/greenteamgo.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/vorionsys/greenteamgo/tree/master/packages/mcp#readme",
