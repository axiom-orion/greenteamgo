{
  "name": "@vorionsys/greenteamgo-policy",
  "version": "0.1.0",
  "description": "GreenTeamGo policy module — versioned rules that allow/deny/gate/challenge an event before a human is paged.",
  "keywords": [
    "policy",
    "rules-engine",
    "ai-agents",
    "authorization",
    "fail-closed"
  ],
  "license": "MIT",
  "author": "Vorion",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vorionsys/greenteamgo-core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axiom-orion/greenteamgo.git",
    "directory": "packages/policy"
  },
  "homepage": "https://github.com/axiom-orion/greenteamgo/tree/master/packages/policy#readme",
  "bugs": {
    "url": "https://github.com/axiom-orion/greenteamgo/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  }
}
