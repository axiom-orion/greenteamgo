{
  "name": "@vorionsys/greenteamgo-notify",
  "version": "0.1.0",
  "description": "GreenTeamGo notify module — inbox item schema and pluggable delivery (webhook now, FCM later).",
  "keywords": [
    "notifications",
    "webhook",
    "push",
    "human-in-the-loop",
    "ai-agents"
  ],
  "license": "MIT",
  "author": "Vorion",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vorionsys/greenteamgo.git",
    "directory": "packages/notify"
  },
  "homepage": "https://github.com/vorionsys/greenteamgo/tree/master/packages/notify#readme",
  "bugs": {
    "url": "https://github.com/vorionsys/greenteamgo/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  }
